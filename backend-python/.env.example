# =================================
# Shree Anna Python Backend - Environment Variables
# =================================
# Copy this file to .env and update values

# Server
ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8005

# Database - SQLite for local dev, PostgreSQL for Supabase production
# For Supabase: Go to Project Settings → Database → Connection String
DATABASE_URL=sqlite:///./shreeanna.db
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres



# JWT Authentication
JWT_SECRET_KEY=shreeanna-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7

# Security
PAYLOAD_SALT=shreeanna-payload-salt-change-me
SERVER_SIGNING_KEY=shreeanna-signing-key-change-me-min-32-chars

# Twilio SMS (leave empty for mock mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OpenWeatherMap (leave empty for mock mode)
OPENWEATHER_API_KEY=

# Reverie Voice Bot
REVERIE_WEBHOOK_SECRET=reverie-webhook-secret-change-me
REVERIE_API_KEY=

# Google Cloud Speech-to-Text & Text-to-Speech
# Option 1: Set path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Option 2: Use API key (limited features)
GOOGLE_CLOUD_API_KEY=

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Rate Limiting
OTP_RATE_LIMIT_PER_HOUR=3
API_RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
