# =================================
# Shree Anna Frontend - Environment Variables
# =================================
# Copy this file to .env.local and update values

# Backend API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8005
NEXT_PUBLIC_API_VERSION=v1

# Development Mode
# Set to true to enable mock OTP and other dev features
NEXT_PUBLIC_DEV_MODE=true
NEXT_PUBLIC_DEV_OTP=123456

# Feature Flags
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_ENABLE_OFFLINE=true
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=false

# PWA Configuration
# VAPID public key for push notifications (optional)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=

# Sentry Error Tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=

# Map Configuration (optional)
NEXT_PUBLIC_MAPBOX_TOKEN=
