# JSON Data Storage
# =============================================================================
/backend/data/*.json
!/backend/data/.gitkeep
/data/*.json
!/data/.gitkeep

# =============================================================================
# Prisma
# =============================================================================
/backend/prisma/migrations/**/migration_lock.toml

# =============================================================================
# Python Backend
# =============================================================================

# Virtual environment
/backend-python/venv/
/backend-python/.venv/
venv/
.venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Python distribution/packaging
/backend-python/dist/
/backend-python/build/
/backend-python/*.egg-info/
*.egg

# Python testing
/backend-python/.pytest_cache/
/backend-python/.coverage
/backend-python/htmlcov/
.pytest_cache/

# Python type checking
/backend-python/.mypy_cache/
.mypy_cache/

# Python environment
/backend-python/.env
/backend-python/*.db
/backend-python/*.sqlite
/backend-python/*.sqlite3

# Python uploads
/backend-python/uploads/*
!/backend-python/uploads/.gitkeep

# Python logs
/backend-python/logs/*
!/backend-python/logs/.gitkeep

# Python data
/backend-python/data/*
!/backend-python/data/.gitkeep
TASKS.md

# Google Cloud / Firebase service account credentials
*.json
!package.json
!package-lock.json
!tsconfig.json
!components.json
!jest.config.json

# Local test scripts at root
test_developer_api.py

